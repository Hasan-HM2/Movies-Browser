{
	"search.exclude": {
		"**/node_modules": true,
		"**/bower_components": true,
		"**/build": true,
		"**/dist": true
	},
	"files.watcherExclude": {
		"**/node_modules/**": true,
		"**/dist/**": true,
		"**/build/**": true
	},
	"typescript.disableAutomaticTypeAcquisition": true,
	"editor.formatOnSave": true,
	"editor.defaultFormatter": "biomejs.biome"
}
